# Example env vars for production support delivery
# Forward support requests to a webhook (preferred)
SUPPORT_WEBHOOK_URL=https://your-webhook.example.com/receive

# Or, use SendGrid to email requests
SUPPORT_SENDGRID_API_KEY=SG.xxxxx
SUPPORT_TO_EMAIL=support@example.com
SUPPORT_FROM_EMAIL=noreply@example.com

# Optional: require reCAPTCHA tokens
SUPPORT_RECAPTCHA_SECRET=

# Rate limiting (ms window and max requests per IP)
SUPPORT_RATE_LIMIT_WINDOW_MS=900000
SUPPORT_RATE_LIMIT_MAX=10
